# GroupChat Agent
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=INFO

# LLM config
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
OPENAI_API_KEY=your_openai_api_key_here

# Optional observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=alpha-agents-groupchat

# Optional AWS/Bedrock
AWS_REGION=us-east-1
AWS_PROFILE=
AWS_ACCOUNT=

# Agent Registry Configuration
AGENT_REGISTRY_URL=http://localhost:8000
VALUATION_AGENT_URL=http://localhost:3001
SENTIMENT_AGENT_URL=http://localhost:3002
FUNDAMENTAL_AGENT_URL=http://localhost:3003

# Specialist Agent Names (for registry lookup)
VALUATION_AGENT_NAME=valuation
SENTIMENT_AGENT_NAME=sentiment
FUNDAMENTAL_AGENT_NAME=fundamental

# Debate Configuration
MAX_DEBATE_ROUNDS=5
CONSENSUS_THRESHOLD=0.75
DEBATE_TIMEOUT=300
COLLABORATION_MODE=debate

# Analysis Configuration
MIN_AGENT_RESPONSES=2
CONSOLIDATION_STRATEGY=weighted_consensus
ENABLE_DISCUSSION_LOGS=true