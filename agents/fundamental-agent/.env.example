# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# LLM Provider Configuration
LLM_PROVIDER=openai  # Options: openai, bedrock
LLM_MODEL=deepseek-chat    # For OpenAI: gpt-4o, gpt-4o-mini | For Bedrock: claude-sonnet-4-20250514-v1:0

LANGCHAIN_TRACING_V2=false
LANGSMITH_TRACING=false

# Server Configuration
HOST=0.0.0.0
PORT=3003

# Agent Configuration
AGENT_NAME=fundamental-agent
AGENT_VERSION=1.0.0
LOG_LEVEL=INFO

# Financial Analysis Configuration
MAX_FINANCIAL_PERIODS=5
ANALYSIS_DEPTH=comprehensive
SECTOR_COMPARISON_ENABLED=true

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_ANALYSIS=50
SIMILARITY_THRESHOLD=0.7